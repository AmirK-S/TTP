---
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { experiences, projects, techStack } from '@/data/portfolio';

// Attempt to import the photo -- if file doesn't exist, amirPhoto stays null.
let amirPhoto: ImageMetadata | null = null;
try {
  const photoModule = import.meta.glob<{ default: ImageMetadata }>('/src/assets/amir-photo.{jpg,jpeg,png,webp}', { eager: true });
  const firstMatch = Object.values(photoModule)[0];
  if (firstMatch) amirPhoto = firstMatch.default;
} catch {}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="about" class="relative px-6 py-32 md:py-48" data-section-portfolio>
  <div class="mx-auto max-w-5xl">
    <!-- Section heading -->
    <div class="mb-20 md:mb-24 text-center" data-portfolio-heading>
      <h2 class="text-heading font-bold tracking-tight">
        <span class="inline-block bg-gradient-to-r from-white to-slate-400 bg-clip-text text-transparent">
          {t('portfolio.heading')}
        </span>
      </h2>
      <p class="mt-4 text-body-lg text-slate-400">
        {t('portfolio.subheading')}
      </p>
    </div>

    <!-- Founder card -->
    <div class="rounded-2xl bg-gradient-to-b from-indigo-500/20 via-transparent to-purple-500/10 p-px" data-portfolio-founder>
      <div class="rounded-[calc(1rem-1px)] bg-white/[0.05] backdrop-blur-sm p-6 md:p-8">
        <div class="flex flex-col items-center gap-6 md:flex-row md:items-start">
          <!-- Photo / placeholder -->
          {amirPhoto ? (
            <Image
              src={amirPhoto}
              alt="Amir Kellou-Sidhoum"
              width={320}
              height={320}
              quality={90}
              class="h-32 w-32 flex-shrink-0 rounded-2xl object-cover md:h-40 md:w-40"
              loading="lazy"
            />
          ) : (
            <div class="flex h-32 w-32 flex-shrink-0 items-center justify-center rounded-2xl border border-white/10 bg-gradient-to-br from-indigo-500/20 to-purple-500/20 md:h-40 md:w-40">
              <span class="text-2xl font-bold text-white/60">AK</span>
            </div>
          )}

          <!-- Bio content -->
          <div>
            <div class="flex items-center gap-3">
              <h3 class="text-subheading font-bold text-white">Amir Kellou-Sidhoum</h3>
              <a
                href="https://www.linkedin.com/in/amirks/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/[0.03] px-2.5 py-1 text-xs text-slate-400 transition-all hover:border-indigo-400/30 hover:bg-indigo-500/10 hover:text-indigo-300"
              >
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn
              </a>
            </div>
            <span class="mt-2 inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1 text-xs text-slate-400">
              {t('portfolio.credentials')}
            </span>
            <p class="mt-1 text-base text-slate-400">
              {t('portfolio.title')}
            </p>
            <p class="mt-3 text-body text-slate-400">
              {t('portfolio.bio')}
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Experience section -->
    <h3 class="mb-6 mt-16 text-subheading font-semibold text-white" data-portfolio-exp-heading>
      {t('portfolio.exp.heading')}
    </h3>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" data-spotlight>
      {experiences.map((exp) => (
        <div class="gradient-border-animated" data-portfolio-exp>
          <div class="rounded-[calc(1rem-1px)] bg-slate-950/95 backdrop-blur-sm p-6 h-full" data-spotlight-card>
            <div class="flex items-center justify-between gap-2">
              <span class="text-base font-semibold text-white">
                {t(`${exp.key}.title` as any)}
              </span>
              {exp.period && (
                <span class="text-sm text-slate-500">{exp.period}</span>
              )}
            </div>
            <p class="mt-2 text-base leading-relaxed text-slate-400">
              {t(`${exp.key}.desc` as any)}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Projects section -->
    <h3 class="mb-6 mt-16 text-subheading font-semibold text-white" data-portfolio-proj-heading>
      {t('portfolio.proj.heading')}
    </h3>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2" data-spotlight>
      {projects.map((proj) => (
        <div class="gradient-border-animated" data-portfolio-proj>
          <div class="rounded-[calc(1rem-1px)] bg-slate-950/95 backdrop-blur-sm p-6 h-full" data-spotlight-card>
            <span class="text-xl font-semibold text-white">
              {t(`${proj.key}.title` as any)}
            </span>
            <p class="mt-2 text-base leading-relaxed text-slate-400">
              {t(`${proj.key}.desc` as any)}
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              {proj.techStack.map((tech) => (
                <span class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1 text-xs text-slate-400">
                  {tech}
                </span>
              ))}
            </div>
            <div class="mt-4 flex gap-3">
              <a
                href={proj.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-indigo-400 transition-colors hover:text-indigo-300"
              >
                {t('portfolio.viewProject')}
              </a>
              {proj.github && (
                <a
                  href={proj.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-indigo-400 transition-colors hover:text-indigo-300"
                >
                  {t('portfolio.viewGithub')}
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Tech stack section -->
    <h3 class="mb-6 mt-16 text-subheading font-semibold text-white" data-portfolio-tech-heading>
      {t('portfolio.tech.heading')}
    </h3>
    <div class="flex flex-wrap justify-center gap-3" data-portfolio-tech>
      {techStack.map((tech) => (
        <div class="flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-4 py-2 transition-all hover:border-white/20 hover:bg-white/[0.05]">
          <div class="h-2 w-2 rounded-full" style={`background-color: ${tech.color}`}></div>
          <span class="text-sm font-medium text-slate-300">{tech.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector("[data-section-portfolio]");
  if (section) {
    const mm = gsap.matchMedia();

    mm.add({
      isDesktop: "(min-width: 768px) and (prefers-reduced-motion: no-preference)",
      isMobile: "(max-width: 767px) and (prefers-reduced-motion: no-preference)",
      reduceMotion: "(prefers-reduced-motion: reduce)",
    }, (context) => {
      const { isDesktop, isMobile, reduceMotion } = context.conditions;
      if (reduceMotion) return;

      const heading = section.querySelector("[data-portfolio-heading]");
      const founderCard = section.querySelector("[data-portfolio-founder]");
      const expHeading = section.querySelector("[data-portfolio-exp-heading]");
      const expCards = gsap.utils.toArray("[data-portfolio-exp]");
      const projHeading = section.querySelector("[data-portfolio-proj-heading]");
      const projCards = gsap.utils.toArray("[data-portfolio-proj]");
      const techHeading = section.querySelector("[data-portfolio-tech-heading]");
      const techStack = section.querySelector("[data-portfolio-tech]");

      // Each group has its own trigger — creates sequential reveal as you scroll
      const ta = "play none none none";

      // Section heading: scrubbed fade up
      gsap.from(heading, {
        opacity: 0,
        y: 30,
        immediateRender: false,
        scrollTrigger: {
          trigger: heading,
          scrub: 1,
          start: "top 90%",
          end: "top 60%",
        },
      });

      // Founder card: slide from left
      gsap.from(founderCard, {
        opacity: 0,
        x: isDesktop ? -80 : -40,
        immediateRender: false,
        duration: 1,
        ease: "power3.out",
        scrollTrigger: { trigger: founderCard, start: "top 85%", toggleActions: ta },
      });

      // Experience cards: slide from right
      gsap.from(expCards, {
        opacity: 0,
        x: isDesktop ? 60 : 30,
        immediateRender: false,
        stagger: 0.12,
        duration: 0.8,
        ease: "power3.out",
        scrollTrigger: { trigger: expCards[0], start: "top 85%", toggleActions: ta },
      });

      // Projects: scale up from center
      gsap.from(projCards, {
        opacity: 0,
        scale: 0.9,
        immediateRender: false,
        stagger: 0.15,
        duration: 0.8,
        ease: "back.out(1.4)",
        scrollTrigger: { trigger: projCards[0], start: "top 85%", toggleActions: ta },
      });

      // Tech stack: slide up
      gsap.from(techStack, {
        opacity: 0,
        y: 30,
        immediateRender: false,
        duration: 0.6,
        scrollTrigger: { trigger: techStack, start: "top 85%", toggleActions: ta },
      });
    });
  }
</script>
