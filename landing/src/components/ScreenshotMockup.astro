---
---

<div class="mx-auto w-full max-w-lg">
  <!-- macOS Window Chrome -->
  <div class="rounded-xl border border-white/10 bg-slate-900/80 shadow-2xl shadow-black/50">
    <!-- Title bar -->
    <div class="flex items-center gap-2 border-b border-white/5 px-4 py-3">
      <span class="h-3 w-3 rounded-full bg-red-500/80"></span>
      <span class="h-3 w-3 rounded-full bg-yellow-500/80"></span>
      <span class="h-3 w-3 rounded-full bg-green-500/80"></span>
      <span class="ml-2 text-xs text-slate-500">TTP - Talk To Paste</span>
    </div>

    <!-- Window Content -->
    <div class="p-6">
      <!-- Simulated desktop with text editor -->
      <div class="space-y-3">
        <!-- Simulated text lines -->
        <div class="h-3 w-4/5 rounded bg-slate-700/50"></div>
        <div class="h-3 w-3/5 rounded bg-slate-700/50"></div>
        <div class="h-3 w-full rounded bg-slate-700/50"></div>
        <div class="h-3 w-2/3 rounded bg-slate-700/50"></div>

        <!-- Active transcription line with cursor -->
        <div class="flex items-center gap-2">
          <div class="h-3 w-2/5 rounded bg-slate-600/80"></div>
          <div class="h-4 w-0.5 animate-pulse bg-white/70"></div>
        </div>
      </div>

      <!-- TTP Floating Pill -->
      <div class="mt-6 flex justify-center">
        <div class="flex items-center gap-2 rounded-full border border-green-500/20 bg-green-500/10 px-4 py-2">
          <span class="h-2 w-2 animate-pulse rounded-full bg-green-400"></span>
          <span class="text-xs font-medium text-green-400">Listening...</span>
        </div>
      </div>
    </div>
  </div>
</div>
