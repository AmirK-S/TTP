---
import { getLangFromUrl, useTranslations } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const features = [
  {
    title: t('features.fastTitle'),
    description: t('features.fastDesc'),
    span: true,
    icon: "zap",
  },
  {
    title: t('features.everywhereTitle'),
    description: t('features.everywhereDesc'),
    span: false,
    icon: "globe",
  },
  {
    title: t('features.aiPolishTitle'),
    description: t('features.aiPolishDesc'),
    span: false,
    icon: "sparkles",
  },
  {
    title: t('features.dictionaryTitle'),
    description: t('features.dictionaryDesc'),
    span: true,
    icon: "book",
  },
  {
    title: t('features.platformsTitle'),
    description: t('features.platformsDesc'),
    span: false,
    icon: "laptop",
  },
  {
    title: t('features.byokTitle'),
    description: t('features.byokDesc'),
    span: false,
    icon: "key",
  },
  {
    title: t('features.privacyTitle'),
    description: t('features.privacyDesc'),
    span: false,
    icon: "shield",
  },
  {
    title: t('features.updatesTitle'),
    description: t('features.updatesDesc'),
    span: false,
    icon: "refresh",
  },
];
---

<section id="features" data-snap-section data-section-features class="relative px-6 py-32 md:py-48">
  <div class="mx-auto max-w-5xl">
    <!-- Section heading -->
    <div data-features-heading class="mb-20 md:mb-24 text-center">
      <h2 class="text-heading font-bold tracking-tight">
        <span class="inline-block bg-gradient-to-r from-white to-slate-400 bg-clip-text text-transparent">
          {t('features.heading')}
        </span>
      </h2>
      <p class="mt-4 text-body-lg text-slate-400">
        {t('features.subheading')}
      </p>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4" data-spotlight>
      {features.map((feature) => (
        <div
          data-feature-card
          class:list={[
            "gradient-border-animated",
            feature.span && "sm:col-span-2",
          ]}
        >
          <div class="rounded-[calc(1rem-1px)] bg-slate-950/95 backdrop-blur-sm p-6 h-full" data-spotlight-card>
            <!-- Icon -->
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg border border-white/10 bg-white/5">
              {feature.icon === "zap" && (
                <svg class="h-5 w-5 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
                </svg>
              )}
              {feature.icon === "globe" && (
                <svg class="h-5 w-5 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10" />
                  <line x1="2" y1="12" x2="22" y2="12" />
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                </svg>
              )}
              {feature.icon === "sparkles" && (
                <svg class="h-5 w-5 text-violet-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z" />
                  <path d="M5 3v4M19 17v4M3 5h4M17 19h4" />
                </svg>
              )}
              {feature.icon === "book" && (
                <svg class="h-5 w-5 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                  <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
                </svg>
              )}
              {feature.icon === "laptop" && (
                <svg class="h-5 w-5 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 16V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v9m16 0H4m16 0 1.28 2.55a1 1 0 0 1-.9 1.45H3.62a1 1 0 0 1-.9-1.45L4 16" />
                </svg>
              )}
              {feature.icon === "key" && (
                <svg class="h-5 w-5 text-orange-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m21 2-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0 3 3L22 7l-3-3m-3.5 3.5L19 4" />
                </svg>
              )}
              {feature.icon === "shield" && (
                <svg class="h-5 w-5 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" />
                  <path d="m9 12 2 2 4-4" />
                </svg>
              )}
              {feature.icon === "refresh" && (
                <svg class="h-5 w-5 text-pink-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
                  <path d="M3 3v5h5" />
                  <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16" />
                  <path d="M16 16h5v5" />
                </svg>
              )}
            </div>

            <!-- Title -->
            <h3 class="mb-1.5 text-base font-semibold text-white">
              {feature.title}
            </h3>

            <!-- Description -->
            <p class="text-sm leading-relaxed text-slate-400">
              {feature.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector("[data-section-features]");
  if (section) {
    const mm = gsap.matchMedia();

    mm.add({
      isDesktop: "(min-width: 768px) and (prefers-reduced-motion: no-preference)",
      isMobile: "(max-width: 767px) and (prefers-reduced-motion: no-preference)",
      reduceMotion: "(prefers-reduced-motion: reduce)",
    }, (context) => {
      const { isDesktop, isMobile, reduceMotion } = context.conditions;
      if (reduceMotion) return;

      const heading = section.querySelector("[data-features-heading]");
      const cards = gsap.utils.toArray("[data-feature-card]");

      // Heading: scrubbed scale-up tied to scroll position
      // Desktop gets blur-in for premium feel; mobile skips filter:blur (not composited, hurts Lighthouse)
      if (isDesktop) {
        gsap.from(heading, {
          scale: 0.85,
          opacity: 0,
          filter: "blur(6px)",
          scrollTrigger: {
            trigger: heading,
            scrub: 1,
            start: "top 90%",
            end: "top 50%",
          },
        });
      } else if (isMobile) {
        gsap.from(heading, {
          scale: 0.9,
          opacity: 0,
          scrollTrigger: {
            trigger: heading,
            scrub: 1,
            start: "top 95%",
            end: "top 65%",
          },
        });
      }

      // Cards: each row fades up as it enters viewport
      const rowSize = isDesktop ? 4 : (isMobile ? 1 : 2);
      for (let i = 0; i < cards.length; i += rowSize) {
        const row = cards.slice(i, i + rowSize);
        gsap.from(row, {
          opacity: 0,
          y: 60,
          immediateRender: false,
          stagger: 0.1,
          duration: 0.8,
          ease: "power3.out",
          scrollTrigger: {
            trigger: row[0],
            start: "top 90%",
            toggleActions: "play none none none",
          },
        });
      }
    });
  }
</script>
